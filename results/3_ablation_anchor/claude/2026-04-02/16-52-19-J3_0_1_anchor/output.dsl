Message J3_0 Translation Trees {
    ACTION {
        A.DISCARD MESSAGE
        B.FWD APPROPRIATE INITIAL SEQUENCE
        H.GO TO NEXT NUMERICAL TEST NODE
        Z.END TRANSLATION


}
CONDITION {
    N1:EXERCISE INDICATOR = 1
    N2:PERIODIC REPORT INDICATOR = 2 WITH COURSE OR SPEED = NO STATEMENT
    N3:POINT TYPE OR POINT AMPLIFICATION IS UNDEFINED OR HAS NO LINK 11/11B EQUIVALENT
    N4:LINE/AREA CONTINUATION INDICATOR = 1
    N5:POINT/LINE/AREA DESCRIPTOR, 1 = 2
    N6:THIS IS INITIAL REPORT FROM DATA SOURCE FOR THIS TN
    N7:SPECIAL PROCESSING INDICATOR HAS CHANGED
}
IF (N1) {
    EXECUTE(A, Z)
}
ELSE {
    IF (N2) {
        EXECUTE(A, Z)


}
ELSE {
    IF (N3) {
        EXECUTE(A, Z)


}
ELSE {
    IF (N4) {
        EXECUTE(A, Z)


}
ELSE {
    IF (N5) {
        EXECUTE(A, Z)


}
ELSE {
    IF (N6) {
        EXECUTE(B, H, Z)


}
ELSE {
    IF (N7) {
        EXECUTE(B, H, Z)


}
ELSE {
    EXECUTE(H)
}
}
}
}
}
}
}
}