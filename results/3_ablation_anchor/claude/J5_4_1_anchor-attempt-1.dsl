Message J5.4 Translation Trees {
    ACTION {
        A. FWD M.4D/M.84D INITIAL SEQUENCE
        B. FWD M.4D/M.84D/M.4B INITIAL SEQUENCE
        C. FWD M.4D/M.84D SEQUENCE
        D. FWD M.4D/M.84D/M.4B SEQUENCE
        E. GO TO TEST NODE 4
        F. FWD APPROPRIATE INITIAL SEQUENCE
        G. FWD M.9A(AC=0, SI=1)
        H. FWD M.9A(AC=5)
        I. FWD M.9A(AC=7)
        J. RETAIN ALERT STATUS (ON/OFF) IN FJU DATA BASE
        K. GO TO TEST NODE 5
        Z. END TRANSLATION


}
CONDITION {
    N1: THIS IS INITIAL REPORT FROM THE DATA SOURCE
    N2: SPECIAL PROCESSING INDICATOR HAS CHANGED
    N3: MINUTE OR HOUR OTHER THAN NO STATEMENT
    N4: SIMULATION INDICATOR = 1
    N5: FORCE TELL INDICATOR HAS CHANGED
    N6: EMERGENCY INDICATOR HAS CHANGED
    N7: EMERGENCY INDICATOR = 1
    N8: FORCE TELL INDICATOR = 1
}
IF (N1) {
    IF (N3) {
        EXECUTE(B, E)


}
ELSE {
    EXECUTE(A, E)
}
}
ELSE {
    IF (N2) {
        IF (N3) {
            EXECUTE(B, E)


    }
    ELSE {
        EXECUTE(A, E)


}
}
ELSE {
    IF (N3) {
        EXECUTE(D, E)


}
ELSE {
    EXECUTE(C, E)
}
}
}
}
