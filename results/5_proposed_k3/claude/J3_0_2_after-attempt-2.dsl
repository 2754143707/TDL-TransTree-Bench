Message J3_0 Translation Trees {
ACTION {
A. DISCARD MESSAGE.
B. FWD APPROPRIATE INITIAL SEQUENCE.
C. FWD M.5.
D. FWD M.85.
E. FWD M.9A(AC=0, SI=1), IF APPROPRIATE.
F. FWD M.9A(AC=5).
G. FWD M.9A(AC=7).
H. GO TO NEXT NUMERICAL TEST NODE.
I. GO TO TEST NODE 11.
J. GO TO TEST NODE 16.
K. FWD M.4A/M.84A.
L. FWD M.4C/M.84C.
M. FWD M.4B.
N. RETAINED DATA IS COMBINED WITH FOLLOWING J3.0 HAVING REMAINING TIME DATA.
O. GO TO TEST NODE 26.
P. GO TO TEST NODE 27.
Q. FWD M.9F(AC=0)/M.89F(AC=0).
R. FWD M.9F(AC=1).
S. COMBINE DATA WITH PRECEDING J3.0 HAVING REMAINING TIME DATA.
T. FWD M.9B.
Z. END TRANSLATION.
}
CONDITION {
C1: EXERCISE INDICATOR = 1.
C2: PERIODIC REPORT INDICATOR = 2 WITH COURSE OR SPEED = NO STATEMENT.
C3: POINT TYPE OR POINT AMPLIFICATION IS UNDEFINED OR HAS NO LINK 11/11B EQUIVALENT.
C4: LINE/AREA CONTINUATION INDICATOR = 1.
C5: POINT/LINE/AREA DESCRIPTOR, 1 = 2.
C6: THIS IS INITIAL REPORT FROM DATA SOURCE FOR THIS TN.
C7: SPECIAL PROCESSING INDICATOR HAS CHANGED.
C8: SIMULATION INDICATOR = 1.
C9: FORCE TELL INDICATOR = 1.
C10: FORCE TELL INDICATOR HAS CHANGED.
C11: POINT TYPE (PT) = 7 OR 8.
C12: PT = 0 AND POINT AMP = 3 OR 6 AND J3.0C5 WORD INCLUDED.
C13: TRACK NUMBER, RELATED 2 IS OTHER THAN NO STATEMENT.
C14: SLAVED INDICATOR = 1.
C15: HOUR, MINUTE, ALTITUDE, COURSE, SPEED OR TN, RELATED IS OTHER THAN NO STATEMENT.
C16: PT = 7, POINT AMPLIFICATION = 0-5, OR POINT AMP = 10 AND NO J3.0C3 WORD WAS RECEIVED.
C17: PT = 7, POINT AMPLIFICATION = 6 OR 13.
C18: PT = 7, POINT AMPLIFICATION = 8.
C19: PT = 7, POINT AMPLIFICATION = 9, OR POINT AMP = 10 AND A J3.0C3 AND/OR A J3.0C4 WORD WAS RECEIVED.
C20: PT = 8, POINT AMPLIFICATION = 0 OR 1.
C21: PT = 8, POINT AMPLIFICATION = 2.
C22: AREA MAJOR AXIS, AREA MINOR AXIS, OR SQUARE/CIRCLE SWITCH = NO STATEMENT OR UNDEFINED.
C23: TIME (HOURS/MINUTES) OTHER THAN NO STATEMENT.
C24: TIME FUNCTION = 0, 1, OR 5.
C25: TIME FUNCTION = 1.
C26: TIME FUNCTION = 2.
C27: COURSE, SPEED, OR TN, RELATED OTHER THAN NO STATEMENT.
}
IF (C1) {
EXECUTE(A, Z)
} ELSE {
IF (C2) {
EXECUTE(A, Z)
} ELSE {
IF (C3) {
EXECUTE(A, Z)
} ELSE {
IF (C4) {
EXECUTE(A, Z)
} ELSE {
IF (C5) {
EXECUTE(A, Z)
} ELSE {
IF (C6) {
EXECUTE(B, H, Z)
} ELSE {
IF (C7) {
EXECUTE(B, H, Z)
} ELSE {
IF (C8) {
EXECUTE(E, H)
} ELSE {
IF (C9) {
EXECUTE(F, I)
} ELSE {
IF (C10) {
EXECUTE(G, H)
} ELSE {
IF (C11) {
EXECUTE(J)
} ELSE {
IF (C12) {
IF (C13) {
EXECUTE(C, D, T, Z)
} ELSE {
EXECUTE(C, D, Z)
}
} ELSE {
IF (C14) {
IF (C15) {
EXECUTE(C, D, Z)
} ELSE {
EXECUTE(C, Z)
}
} ELSE {
EXECUTE(C, D, Z)
}
}
}
}
}
}
}
}
}
}
}
}
}
